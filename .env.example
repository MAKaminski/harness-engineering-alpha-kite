# Linear API key (create at https://linear.app/settings/api)
# Copy this file to .env and fill in your values. Do not commit .env.
LINEAR_API_KEY=
# Prefer project UUID (from Linear project settings/URL) to avoid API 400 with slugId
LINEAR_PROJECT_ID=
# Or use project slug from URL, e.g. alpha-kite-f0ebf2d85f93
LINEAR_PROJECT_SLUG=
